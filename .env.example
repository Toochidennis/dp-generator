# Leave empty when the API is served from the same origin.
VITE_API_BASE_URL=https://api.example.com

# Public origin used for canonical links and social metadata.
VITE_SITE_URL=https://kids-coding-bootcamp.digitaldreams.ng

# true  -> use the isolated in-memory mock (no backend required)
# false -> call the real backend through the API service layer
VITE_USE_MOCKS=true
